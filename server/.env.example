PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/smart_attendance
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# Comma-separated teacher emails that are allowed to login (accounts must exist in DB).
TEACHER_EMAIL_ALLOWLIST=teacher1@example.com,teacher2@example.com

# Optional: seed script will create/update teachers with this default password.
TEACHER_DEFAULT_PASSWORD=ChangeMe123!

# CORS
CLIENT_ORIGIN=http://localhost:5173

